generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum PermissionStatus {
  PENDING
  APPROVED
  DENIED
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  passwordHash  String
  role      Role
  createdAt DateTime @default(now())

  records            Record[]
  doctorPermissions  Permission[] @relation("DoctorPermissions")
  patientPermissions Permission[] @relation("PatientPermissions")
}

model Record {
  id        Int      @id @default(autoincrement())
  filename  String?
  cid       String
  hash      String
  patientId Int
  createdAt DateTime @default(now())

  patient     User        @relation(fields: [patientId], references: [id])
  permissions Permission[]
}

model Permission {
  id        Int      @id @default(autoincrement())
  recordId  Int
  doctorId  Int
  patientId Int

  status    PermissionStatus @default(PENDING)
  allowed   Boolean          @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  record  Record @relation(fields: [recordId], references: [id])
  doctor  User   @relation("DoctorPermissions", fields: [doctorId], references: [id])
  patient User   @relation("PatientPermissions", fields: [patientId], references: [id])
}